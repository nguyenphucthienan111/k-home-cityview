# ─── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Lấy connection string từ MongoDB Atlas hoặc local
# Ví dụ local:  mongodb://127.0.0.1:27017/k-home-cityview
# Ví dụ Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/k-home-cityview
MONGODB_URI="mongodb://127.0.0.1:27017/k-home-cityview"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Tạo chuỗi ngẫu nhiên mạnh, ví dụ: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_STRING"

# ─── Admin Credentials ───────────────────────────────────────────────────────
# Tên đăng nhập admin
ADMIN_USERNAME="admin"

# Bcrypt hash của mật khẩu — KHÔNG lưu plain text ở đây
# Chạy lệnh sau để tạo hash: node scripts/hash-password.mjs
ADMIN_PASSWORD_HASH="$2b$12$REPLACE_THIS_WITH_REAL_BCRYPT_HASH"
